# Server
PORT=3004
BASE_URL=https://container.paletten-ms.de
HISTORY_MAX=5000

# PostgreSQL (Option A: komplette URL)
# Wird genutzt, wenn keine PG* Variablen gesetzt sind.
# DATABASE_URL=postgresql://containera:containera@127.0.0.1:5432/containeranmeldung

# PostgreSQL (Option B: einzelne Variablen - hat Vorrang)
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=containeranmeldung
PGUSER=containera
PGPASSWORD=containera
# DATABASE_URL=postgresql://DB_USER:DB_PASS@127.0.0.1:5432/containeranmeldung

# PostgreSQL (Option B: einzelne Variablen)
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=containeranmeldung
PGUSER=postgres
PGPASSWORD=BITTE_SETZEN

# Optional: auf true setzen, wenn dein DB-Server TLS erfordert
PGSSL=false
