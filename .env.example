# Server
PORT=3004
BASE_URL=https://container.paletten-ms.de
HISTORY_MAX=5000

# PostgreSQL (Option A: komplette URL)
# Wird genutzt, wenn keine PG* Variablen gesetzt sind.
# DATABASE_URL=postgresql://containera:containera@127.0.0.1:5432/containeranmeldung

# PostgreSQL (Option B: einzelne Variablen - hat Vorrang)
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=containeranmeldung
PGUSER=containera
PGPASSWORD=containera
# DATABASE_URL=postgresql://DB_USER:DB_PASS@127.0.0.1:5432/containeranmeldung

# PostgreSQL (Option B: einzelne Variablen)
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=containeranmeldung
PGUSER=postgres
PGPASSWORD=BITTE_SETZEN

# Optional: auf true setzen, wenn dein DB-Server TLS erfordert
PGSSL=false

# SSO / Admin-Berechtigung
SHARED_AUTH_SECRET=13215489156189421598412
ADMIN_PERMISSION_KEY=integration.container_login
ADMIN_AUTH_DATABASE_URL=postgresql://palettenuser:DEIN_STARKES_PASSWORT@localhost:5432/palettenmanagement
# Optional nur bei abweichendem Schema:
# ADMIN_AUTH_QUERY=SELECT 1 FROM users u JOIN user_roles ur ON ur.user_id=u.id JOIN role_permissions rp ON rp.role_id=ur.role_id JOIN permissions p ON p.id=rp.permission_id WHERE LOWER(u.username)=LOWER($1) AND p.key=$2 LIMIT 1
